<?xml version="1.0" encoding="utf-8"?>
<!--
  FIX #2: Replaced FloatingActionButtons with MaterialButtons throughout.
  FAB does NOT have a .text property — calling binding.btnRecord.text = "..."
  caused a compile-time / ClassCastException crash at runtime.
  All three action buttons are now regular MaterialButtons so .text works.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <!-- Progress -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 / 18"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <!-- Sentence Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/card_repeat">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPEAT AFTER ME"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="#7B1FA2"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvSentence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Good morning, how are you today?"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.3"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press PLAY to hear the sentence, then RECORD to practice"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="32dp" />

    <!-- Action buttons — all MaterialButton so .text property works -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Play (TTS) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlay"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="▶ Play"
            android:textSize="14sp"
            app:backgroundTint="@color/accent_teal"
            app:cornerRadius="12dp" />

        <!-- Record / Stop -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:text="🎙 Record"
            android:textSize="14sp"
            app:backgroundTint="@color/mic_active"
            app:cornerRadius="12dp" />

        <!-- Replay recording -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReplay"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="↩ Replay"
            android:textSize="14sp"
            app:backgroundTint="@color/warning_amber"
            app:cornerRadius="12dp"
            android:enabled="false" />

    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Next sentence -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Next Sentence →"
        app:backgroundTint="@color/primary_blue" />

</LinearLayout>
